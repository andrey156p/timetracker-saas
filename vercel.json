{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/billing?secret=fallback_secret_123",
      "schedule": "0 0 1 * *"
    },
    {
      "path": "/api/cron/push",
      "schedule": "* * * * *"
    }
  ]
}
